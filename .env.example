# ─── Database (libSQL / Turso) ───────────────────────────────────────────────
# Local dev: point at a file → TURSO_DATABASE_URL=file:local.db (no token needed)
# Prod: turso db create mysocials → turso db show mysocials --url / tokens create
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# ─── Better Auth ──────────────────────────────────────────────────────────────
# openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# First superuser. Set to the user id (after signing up) to grant /admin access.
ADMIN_USER_ID=

# ─── Google OAuth (optional) ────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth client ID (Web).
# Authorized redirect URI: <BETTER_AUTH_URL>/api/auth/callback/google
# The "Continue with Google" button stays hidden until both values are set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Email / SMTP (optional) ────────────────────────────────────────────────
# Powers email verification (additive, non-blocking) + password reset. Gmail:
# host smtp.gmail.com, port 465, an App Password as SMTP_PASSWORD. Email features
# stay dormant until all five values are set.
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# ─── Media storage ──────────────────────────────────────────────────────────
# STORAGE_DRIVER=local writes to public/uploads (dev). =r2 uses Cloudflare R2.
STORAGE_DRIVER=local
# Cloudflare R2 (S3-compatible). Egress is free.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL for the bucket (custom domain or https://pub-xxx.r2.dev)
R2_PUBLIC_BASE_URL=

# ─── Polar (subscriptions) ──────────────────────────────────────────────────
# Use sandbox until verified, then 'production'.
POLAR_SERVER=sandbox
POLAR_ACCESS_TOKEN=
POLAR_PRODUCT_ID=
POLAR_WEBHOOK_SECRET=

# ─── Assistant (agentic dashboard, optional) ────────────────────────────────
# Natural-language / voice assistant that runs additive actions (create tabs,
# add links, connect Instagram). OpenAI-compatible chat endpoint. Defaults to
# Groq (free): set GROQ_API_KEY. Override the endpoint/model for another
# provider (e.g. Google AI Studio's OpenAI-compatible URL). Stays dormant until
# a key is set.
GROQ_API_KEY=
# AGENT_API_KEY=          # overrides GROQ_API_KEY
# AGENT_BASE_URL=https://api.groq.com/openai/v1
# AGENT_MODEL=llama-3.3-70b-versatile

# ─── Instagram import (Fase 6, optional) ────────────────────────────────────
# "Instagram API with Instagram Login". Requires a Meta app with the Instagram
# product and an Instagram professional (Business/Creator) account. Register the
# OAuth redirect URI as <BETTER_AUTH_URL>/api/import/instagram/callback. The
# import UI stays hidden until both values are set.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
